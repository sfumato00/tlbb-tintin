#NOP graph tests.;

#CLASS testing READ {./tests/test_common.test.tin};
#CLASS graph READ {./pkg/pkg_travel.tin};
#CLASS path READ {./pkg/pkg_path.tin};

#VARIABLE {Profile[username]} {testgraph};
#VARIABLE {Profile[password]} {Abcd_124};

#ALIAS {XIXIA_DALI_TEST} {
    #EVENT {VARIABLE UPDATED Hooks[session_login][test]} {
        #EVENT {VARIABLE UPDATED Events[travel][trip_complete]} {
            #UNEVENT {VARIABLE UPDATED Events[travel][trip_complete]};
            goto {十字广场 north、south、east、west 和 up};
        };
        goto {皇宫大门 south、eastup 和 westup};
    };
    conn travel;
};


#ALIAS {SHAOLIN_DALI_TEST} {
    #EVENT {VARIABLE UPDATED Hooks[session_login][test]} {
        goto {少室山山脚 south 和 northwest};
    };
    conn travel;
};


#ALIAS {TRAVEL_TEST} {
    #VARIABLE {Test[dest_room]} {%1};
    #EVENT {VARIABLE UPDATED Hooks[session_login][test]} {
        goto {$Test[dest_room]};
    };
    conn travel;
};


#ALIAS {name} {
    commands
} {5};